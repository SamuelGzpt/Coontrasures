# Puerto del servidor
PORT=3000

# URL del frontend (cambiar por tu dominio o IP cuando montes el servidor)
CLIENT_URL=http://localhost:5173

# Secreto para autenticación (CAMBIA esto por algo largo y seguro)
JWT_SECRET=CAMBIA_POR_UN_SECRETO_SEGURO_LARGO

# Contraseña admin (no se usa actualmente, la BD maneja usuarios)
ADMIN_PASSWORD=admin123

# Configuración de la base de datos PostgreSQL
DB_USER=postgres
DB_PASSWORD=TU_PASSWORD_DE_POSTGRESQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cootransures_db
